# 서빙할 HuggingFace 모델 ID (필수)
MODEL_ID=microsoft/Phi-3-mini-4k-instruct

# API 서버 포트
VLLM_PORT=8000

# 외부 노출 시 API 키 인증 (선택)
VLLM_API_KEY=

# HuggingFace gated 모델 접근 토큰 (선택)
HF_TOKEN=

# OpenAI API 호환 시 노출할 모델 이름
SERVED_MODEL_NAME=default

# 최대 컨텍스트 길이 (모델 기본값보다 줄이면 VRAM 절약)
MAX_MODEL_LEN=4096

# GPU 메모리 사용 비율 (0.0 ~ 1.0)
GPU_MEMORY_UTILIZATION=0.9

# 텐서 병렬 GPU 수 (멀티 GPU 사용 시 증가)
TENSOR_PARALLEL_SIZE=1

# 사용할 GPU 수
GPU_COUNT=1
